rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Aturan untuk koleksi 'laptops'
    match /laptops/{laptopId} {
      // Siapapun (user) bisa membaca katalog laptop tanpa login
      allow read: if true;
      
      // Hanya pengguna yang terautentikasi (admin) yang dapat memodifikasi data
      allow write: if request.auth != null;
    }
  }
}
